{
  "$schema": "./node_modules/@angular/cli/lib/config/schema.json",
  "version": 1,
  "cli": {
    "packageManager": "npm",
    "analytics": "618ccf5d-12a6-4adb-8ed4-225611403d39"
  },
  "newProjectRoot": "projects",
  "projects": {
    "bot-app": {
      "projectType": "application",
      "schematics": {
        "@schematics/angular:component": {
          "style": "scss",
          "skipTests": true
        },
        "@schematics/angular:class": {
          "skipTests": true
        },
        "@schematics/angular:directive": {
          "skipTests": true
        },
        "@schematics/angular:guard": {
          "skipTests": true
        },
        "@schematics/angular:interceptor": {
          "skipTests": true
        },
        "@schematics/angular:pipe": {
          "skipTests": true
        },
        "@schematics/angular:resolver": {
          "skipTests": true
        },
        "@schematics/angular:service": {
          "skipTests": true
        }
      },
      "root": "projects/bot-app",
      "sourceRoot": "projects/bot-app/src",
      "prefix": "app",
      "architect": {
        "build": {
          "builder": "@angular-devkit/build-angular:browser",
          "options": {
            "outputPath": "dist/bot-app",
            "index": "projects/bot-app/src/index.html",
            "main": "projects/bot-app/src/main.ts",
            "polyfills": "projects/bot-app/src/polyfills.ts",
            "tsConfig": "projects/bot-app/tsconfig.app.json",
            "inlineStyleLanguage": "scss",
            "assets": [
              "projects/bot-app/src/favicon.ico",
              "projects/bot-app/src/assets"
            ],
            "styles": [
              "node_modules/bootstrap/dist/css/bootstrap.min.css",
              "projects/bot-app/src/styles.scss"
            ],
            "scripts": []
          },
          "configurations": {
            "production": {
              "budgets": [
                {
                  "type": "initial",
                  "maximumWarning": "2mb",
                  "maximumError": "3mb"
                },
                {
                  "type": "anyComponentStyle",
                  "maximumWarning": "100kb",
                  "maximumError": "200kb"
                }
              ],
              "fileReplacements": [
                {
                  "replace": "projects/bot-app/src/environments/environment.ts",
                  "with": "projects/bot-app/src/environments/environment.prod.ts"
                }
              ],
              "outputHashing": "all"
            },
            "development": {
              "buildOptimizer": false,
              "optimization": false,
              "vendorChunk": true,
              "extractLicenses": false,
              "sourceMap": true,
              "namedChunks": true
            }
          },
          "defaultConfiguration": "production"
        },
        "serve": {
          "builder": "@angular-devkit/build-angular:dev-server",
          "configurations": {
            "production": {
              "browserTarget": "bot-app:build:production"
            },
            "development": {
              "browserTarget": "bot-app:build:development"
            }
          },
          "defaultConfiguration": "development"
        },
        "extract-i18n": {
          "builder": "@angular-devkit/build-angular:extract-i18n",
          "options": {
            "browserTarget": "bot-app:build"
          }
        },
        "test": {
          "builder": "@angular-devkit/build-angular:karma",
          "options": {
            "main": "projects/bot-app/src/test.ts",
            "polyfills": "projects/bot-app/src/polyfills.ts",
            "tsConfig": "projects/bot-app/tsconfig.spec.json",
            "karmaConfig": "projects/bot-app/karma.conf.js",
            "inlineStyleLanguage": "scss",
            "assets": [
              "projects/bot-app/src/favicon.ico",
              "projects/bot-app/src/assets"
            ],
            "styles": [
              "node_modules/bootstrap/dist/css/bootstrap.min.css",
              "projects/bot-app/src/styles.scss"
            ],
            "scripts": []
          }
        }
      }
    },
    "bot-lib": {
      "projectType": "library",
      "root": "projects/bot-lib",
      "sourceRoot": "projects/bot-lib/src",
      "prefix": "lib",
      "architect": {
        "build": {
          "builder": "@angular-devkit/build-angular:ng-packagr",
          "options": {
            "project": "projects/bot-lib/ng-package.json"
          },
          "configurations": {
            "production": {
              "tsConfig": "projects/bot-lib/tsconfig.lib.prod.json"
            },
            "development": {
              "tsConfig": "projects/bot-lib/tsconfig.lib.json"
            }
          },
          "defaultConfiguration": "production"
        },
        "test": {
          "builder": "@angular-devkit/build-angular:karma",
          "options": {
            "main": "projects/bot-lib/src/test.ts",
            "tsConfig": "projects/bot-lib/tsconfig.spec.json",
            "karmaConfig": "projects/bot-lib/karma.conf.js"
          }
        }
      }
    },
    "bot-element": {
      "projectType": "application",
      "schematics": {
        "@schematics/angular:component": {
          "style": "scss",
          "skipTests": true
        }
      },
      "root": "projects/bot-element",
      "sourceRoot": "projects/bot-element/src",
      "prefix": "app",
      "architect": {
        "build": {
          "builder": "@angular-devkit/build-angular:browser",
          "options": {
            "outputPath": "dist/bot-element",
            "deleteOutputPath": false,
            "index": "projects/bot-element/src/index.html",
            "main": "projects/bot-element/src/main.ts",
            "polyfills": "projects/bot-element/src/polyfills.ts",
            "tsConfig": "projects/bot-element/tsconfig.app.json",
            "inlineStyleLanguage": "scss",
            "assets": [
              "projects/bot-element/src/favicon.ico",
              "projects/bot-element/src/assets"
            ],
            "styles": [
              "node_modules/bootstrap/dist/css/bootstrap.min.css",
              "projects/bot-element/src/styles.scss"
            ],
            "scripts": []
          },
          "configurations": {
            "production": {
              "budgets": [
                {
                  "type": "initial",
                  "maximumWarning": "2mb",
                  "maximumError": "3mb"
                },
                {
                  "type": "anyComponentStyle",
                  "maximumWarning": "100kb",
                  "maximumError": "200kb"
                }
              ],
              "fileReplacements": [
                {
                  "replace": "projects/bot-element/src/environments/environment.ts",
                  "with": "projects/bot-element/src/environments/environment.prod.ts"
                }
              ],
              "outputHashing": "all",
              "buildOptimizer": true,
              "optimization": true,
              "vendorChunk": true,
              "extractLicenses": true,
              "sourceMap": false,
              "namedChunks": false
            },
            "development": {
              "buildOptimizer": false,
              "optimization": false,
              "vendorChunk": true,
              "extractLicenses": false,
              "sourceMap": true,
              "namedChunks": true
            }
          },
          "defaultConfiguration": "production"
        },
        "serve": {
          "builder": "@angular-devkit/build-angular:dev-server",
          "configurations": {
            "production": {
              "browserTarget": "bot-element:build:production"
            },
            "development": {
              "browserTarget": "bot-element:build:development"
            }
          },
          "defaultConfiguration": "development"
        },
        "extract-i18n": {
          "builder": "@angular-devkit/build-angular:extract-i18n",
          "options": {
            "browserTarget": "bot-element:build"
          }
        },
        "test": {
          "builder": "@angular-devkit/build-angular:karma",
          "options": {
            "main": "projects/bot-element/src/test.ts",
            "polyfills": "projects/bot-element/src/polyfills.ts",
            "tsConfig": "projects/bot-element/tsconfig.spec.json",
            "karmaConfig": "projects/bot-element/karma.conf.js",
            "inlineStyleLanguage": "scss",
            "assets": [
              "projects/bot-element/src/favicon.ico",
              "projects/bot-element/src/assets"
            ],
            "styles": [
              "node_modules/bootstrap/dist/css/bootstrap.min.css",
              "projects/bot-element/src/styles.scss"
            ],
            "scripts": []
          }
        }
      }
    }
  },
  "defaultProject": "bot-lib"
}
