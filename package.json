{
  "name": "bizzy-bot",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve --project=bot-app --port=4300",
    "start:app": "ng serve --project=bot-app --port=4300",
    "start:element": "ng serve --project=bot-element --port=4301",
    "build": "ng build",
    "build:lib": "ng build --project=bot-lib",
    "build:element": "ng build --configuration=production --project=bot-element --build-optimizer --named-chunks=true --output-hashing=none && node build.js",
    "build:bundle": "node build.js",
    "watch": "ng build --watch --configuration development",
    "test": "ng test"
  },
  "private": true,
  "dependencies": {
    "@angular/animations": "^14.2.0",
    "@angular/common": "^14.2.0",
    "@angular/compiler": "^14.2.0",
    "@angular/core": "^14.2.0",
    "@angular/elements": "^14.2.0",
    "@angular/forms": "^14.2.0",
    "@angular/platform-browser": "^14.2.0",
    "@angular/platform-browser-dynamic": "^14.2.0",
    "@angular/router": "^14.2.0",
    "bootstrap": "^4.6.2",
    "rxjs": "~7.5.0",
    "tslib": "^2.3.0",
    "zone.js": "~0.11.4"
  },
  "devDependencies": {
    "@angular-devkit/build-angular": "^14.2.13",
    "@angular/cli": "~14.2.13",
    "@angular/compiler-cli": "^14.2.0",
    "@types/fs-extra": "^9.0.13",
    "@types/node": "^16.18.0",
    "@types/jasmine": "~4.0.0",
    "concat": "^1.0.3",
    "fs-extra": "^10.1.0",
    "jasmine-core": "~4.3.0",
    "karma": "~6.4.0",
    "karma-chrome-launcher": "~3.1.0",
    "karma-coverage": "~2.2.0",
    "karma-jasmine": "~5.1.0",
    "karma-jasmine-html-reporter": "~2.0.0",
    "ng-packagr": "^14.2.2",
    "typescript": "~4.7.2"
  }
}
